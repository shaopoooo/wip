{
  "name": "wip-backend",
  "version": "1.0.0",
  "description": "WIP QR Code Tracking System — Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "NODE_ENV=production tsc --project tsconfig.json",
    "start": "NODE_ENV=production node dist/index.js",
    "test": "NODE_ENV=development jest",
    "migrate:gen": "NODE_ENV=development drizzle-kit generate",
    "migrate": "NODE_ENV=development drizzle-kit migrate",
    "migrate:prod": "NODE_ENV=production node dist/migrate.js",
    "seed": "NODE_ENV=development ts-node src/seed.ts",
    "seed:prod": "NODE_ENV=production node dist/seed.js"
  },
  "dependencies": {
    "bcryptjs": "3.0.3",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "drizzle-orm": "0.45.1",
    "express": "5.2.1",
    "jsonwebtoken": "9.0.3",
    "morgan": "1.10.1",
    "pg": "8.20.0",
    "qrcode": "1.5.4",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "3.0.0",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "1.9.10",
    "@types/node": "22.19.15",
    "@types/pg": "8.20.0",
    "@types/qrcode": "1.5.6",
    "drizzle-kit": "0.31.9",
    "nodemon": "3.1.14",
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  }
}
