# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://wip_user:changeme@db:5432/wip_db
POSTGRES_DB=wip_db
POSTGRES_USER=wip_user
POSTGRES_PASSWORD=changeme

# ── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── JWT ───────────────────────────────────────────────────────────────────────
# openssl rand -hex 64
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Admin seed account (used only on first migrate/seed) ──────────────────────
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=changeme_on_first_login

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://wip.yourfactory.com

# ── Backup (Phase 1 cron) ─────────────────────────────────────────────────────
GCS_BACKUP_BUCKET=gs://your-factory-wip-backup
